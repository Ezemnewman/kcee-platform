# Copy this file to .env and fill in real values.
# .env is already gitignored — never commit real secrets.

# Google Sign-In Client ID
# Get this from Google Cloud Console:
#   1. Go to console.cloud.google.com and create a project (or use an existing one)
#   2. Go to "APIs & Services" -> "Credentials"
#   3. Create an "OAuth client ID" of type "Web application"
#   4. Add http://localhost:5173 to "Authorized JavaScript origins" for local dev
#   5. Copy the generated Client ID below
# Until this is set, the Google sign-in button on the signup page
# renders as a disabled placeholder instead of crashing or faking success.
VITE_GOOGLE_CLIENT_ID=
